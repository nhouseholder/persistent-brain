{
  "_comment": "Drop this mcpServers block into your agent's MCP config. brain-router is the unified interface — it routes queries to engram and mempalace automatically. The direct engram/mempalace servers are kept for advanced operations.",
  "mcpServers": {
    "brain-router": {
      "command": "brain-router",
      "env": {
        "BRAIN_PROJECT": "${BRAIN_PROJECT:-global}",
        "ENGRAM_DB": "${ENGRAM_DB:-$HOME/.engram/engram.db}",
        "MEMPALACE_PALACE": "${MEMPALACE_PALACE:-$HOME/.mempalace/global}"
      }
    },
    "engram": {
      "command": "engram",
      "args": ["mcp"]
    },
    "mempalace": {
      "command": "mempalace-mcp",
      "args": [],
      "env": {
        "MEMPALACE_PALACE": "${MEMPALACE_PALACE:-$HOME/.mempalace/global}"
      }
    }
  }
}
